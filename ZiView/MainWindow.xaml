<Window x:Class="ZiView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ZiView"
        Title="ZiView" Height="800" Width="1200"
        Background="#050505" Foreground="White" 
        WindowStyle="SingleBorderWindow" AllowsTransparency="False"
        AllowDrop="True" Closing="Window_Closing"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <local:HalfLayoutConverter x:Key="HalfLayoutConverter"/>

        <Style x:Key="LineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="#4400FF00"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeDashArray" Value="4 4"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#00FFFF"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" ClipToBounds="True">

        <ContentControl x:Name="ImageContainer" 
                        Background="Black"
                        MouseLeftButtonDown="ImageContainer_MouseLeftButtonDown"
                        MouseLeftButtonUp="ImageContainer_MouseLeftButtonUp"
                        MouseMove="ImageContainer_MouseMove"
                        MouseWheel="ImageContainer_MouseWheel">

            <Border x:Name="ImageBorder" 
                    BorderBrush="#33FFFFFF" 
                    BorderThickness="1" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ImgScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="ImgTranslate" X="0" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>

                <Border.Effect>
                    <local:LensCorrectionEffect x:Name="LensShader" DistortionAmount="0.0"/>
                </Border.Effect>

                <Image x:Name="MainImage" 
                       Stretch="Uniform" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       RenderOptions.EdgeMode="Aliased">
                </Image>
            </Border>
        </ContentControl>

        <Canvas x:Name="ReticleOverlay" IsHitTestVisible="False" Visibility="Collapsed">
            <Line Style="{StaticResource LineStyle}"
                  X1="0" 
                  Y1="{Binding ActualHeight, ElementName=RootGrid, Converter={StaticResource HalfLayoutConverter}}" 
                  X2="{Binding ActualWidth, ElementName=RootGrid}" 
                  Y2="{Binding ActualHeight, ElementName=RootGrid, Converter={StaticResource HalfLayoutConverter}}"/>
            <Line Style="{StaticResource LineStyle}"
                  X1="{Binding ActualWidth, ElementName=RootGrid, Converter={StaticResource HalfLayoutConverter}}" 
                  Y1="0" 
                  X2="{Binding ActualWidth, ElementName=RootGrid, Converter={StaticResource HalfLayoutConverter}}" 
                  Y2="{Binding ActualHeight, ElementName=RootGrid}"/>
        </Canvas>

        <Border x:Name="NotificationBadge" 
                Background="#CC111111" CornerRadius="4" 
                Padding="12,6" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,100"
                Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="20">
            <TextBlock x:Name="NotificationText" Foreground="#FFFFFF" FontSize="12" FontFamily="Consolas"/>
        </Border>

        <Border x:Name="Sidebar" Width="260" HorizontalAlignment="Right" Background="#F80A0A0A" 
                BorderBrush="#00FFFF" BorderThickness="1,0,0,0" Panel.ZIndex="10">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SidebarTransform" X="260"/>
            </Border.RenderTransform>
            <StackPanel Margin="20">
                <TextBlock Text="ZiView SETTINGS" FontSize="16" FontWeight="Bold" Foreground="#00FFFF" Margin="0,0,0,25"/>
                <CheckBox x:Name="CheckSpread" Content="Spread View (右開き)" IsChecked="False" Click="OnSettingChanged"/>
                <CheckBox x:Name="CheckAutoDetect" Content="Auto Page Order" IsChecked="False" Click="OnSettingChanged"/>
                <CheckBox x:Name="CheckReticle" Content="Show Reticle" IsChecked="False" Click="OnReticleSettingChanged"/>
                <CheckBox x:Name="CheckPrefetch" Content="AI Prefetch" IsChecked="True"/>

                <Separator Background="#222" Margin="0,15"/>

                <TextBlock Text="LENS CORRECTION (K)" Margin="0,0,0,5" Foreground="#666" FontSize="10" FontWeight="Bold"/>
                <CheckBox x:Name="CheckLens" Content="Enable Correction" IsChecked="False" Click="OnLensSettingChanged"/>
                <TextBlock Text="CORRECTION AMOUNT [ / ]" Margin="0,5,0,5" Foreground="#666" FontSize="10" FontWeight="Bold"/>
                <Slider x:Name="LensSlider" Minimum="-2.0" Maximum="2.0" Value="0.40" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="OnLensSliderChanged"/>

                <Separator Background="#222" Margin="0,15"/>

                <TextBlock Text="AI SPLIT RATIO" Margin="0,0,0,10" Foreground="#666" FontSize="10" FontWeight="Bold"/>
                <Slider x:Name="SplitSlider" Minimum="0" Maximum="100" Value="100" TickFrequency="1" IsSnapToTickEnabled="True"/>

                <TextBlock Text="SYSTEM MONITOR" Margin="0,30,0,10" Foreground="#666" FontSize="10" FontWeight="Bold"/>
                <Border Background="#121212" CornerRadius="2" Padding="12" BorderBrush="#222" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="StatusText" Text="Ready" Foreground="#00FFFF" TextWrapping="Wrap" FontSize="11"/>
                        <TextBlock x:Name="MemoryText" Text="RAM: -- MB" Foreground="#00FF00" Margin="0,8,0,0" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border x:Name="BottomBar" Height="80" VerticalAlignment="Bottom" Background="#F80F0F0F" 
                BorderBrush="#1A1A1A" BorderThickness="0,1,0,0" Panel.ZIndex="10">
            <Border.RenderTransform>
                <TranslateTransform x:Name="BottomBarTransform" Y="80"/>
            </Border.RenderTransform>
            <DockPanel Margin="30,0">
                <TextBlock x:Name="PageText" Text="P.0 / 0" VerticalAlignment="Center" Width="120" Foreground="#00FFFF" FontWeight="Bold" FontSize="14"/>
                <Slider x:Name="PageSlider" VerticalAlignment="Center" IsDirectionReversed="True" Minimum="0" Maximum="0" Margin="10,0"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>