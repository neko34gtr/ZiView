<Window x:Class="ZiView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ZiView"
        Title="ZiView" Height="800" Width="1200"
        Background="#0A0A0C" Foreground="White" 
        WindowStyle="SingleBorderWindow" AllowsTransparency="False"
        AllowDrop="True" Closing="Window_Closing"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <local:HalfLayoutConverter x:Key="LayoutConverter"/>

        <!-- ===== デザイントークン ===== -->
        <SolidColorBrush x:Key="AccentBrush" Color="#00E5FF"/>
        <SolidColorBrush x:Key="AccentDimBrush" Color="#0F5C66"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#101014"/>
        <SolidColorBrush x:Key="CardBrush" Color="#16161B"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#232329"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F2F2F5"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8A8A93"/>
        <SolidColorBrush x:Key="TextCaptionBrush" Color="#6C6C76"/>

        <Style x:Key="LineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="#4400FF00"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeDashArray" Value="4 4"/>
        </Style>

        <!-- セクション見出し（キャプション階層） -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextCaptionBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- カードパネル（表面の階層/Elevation） -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- スライダー：進捗フィル付きの薄型トラック＋グロー付きサム -->
        <Style TargetType="Slider">
            <Setter Property="Background" Value="#2A2A30"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="26">
                            <Border Background="#1C1C21" BorderBrush="#2A2A30" BorderThickness="1"
                                    Height="4" VerticalAlignment="Center" CornerRadius="2"/>
                            <Track Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="{StaticResource AccentBrush}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}" Height="4"
                                                        CornerRadius="2" VerticalAlignment="Center" Opacity="0.85"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{x:Null}" Template="{x:Null}" Background="Transparent"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="15" Height="15" Background="#FFFFFF" BorderBrush="{StaticResource AccentBrush}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#00E5FF" BlurRadius="10" ShadowDepth="0" Opacity="0.75"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- チェックボックス：トグルスイッチ表現 -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Border x:Name="Track" Grid.Column="1" Width="38" Height="20" CornerRadius="10"
                                    Background="#2A2A30" BorderBrush="#38383F" BorderThickness="1">
                                <Ellipse x:Name="Knob" Width="14" Height="14" Fill="#8A8A93"
                                         HorizontalAlignment="Left" Margin="2,0,0,0"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentDimBrush}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Knob" Property="Fill" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Knob" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ボタン：角丸＋ホバーで反転 -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="#0A0A0C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- セパレーター：控えめなヘアライン -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,4,0,16"/>
        </Style>

        <!-- コンボボックス：角丸＋アクセント枠 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBg" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBg" Property="Background" Value="{StaticResource AccentDimBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="Toggle" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                                                BorderThickness="1" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"
                                                                   Content="{TemplateBinding Content}"/>
                                                <Path Grid.Column="1" Margin="0,0,10,0" Data="M0,0 L6,6 L12,0" Stroke="{StaticResource TextSecondaryBrush}"
                                                      StrokeThickness="1.5" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                   ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                   Margin="{TemplateBinding Padding}"/>
                            </ToggleButton>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="220" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="4" Opacity="0.4"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="4" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" ClipToBounds="True">

        <ContentControl x:Name="ImageContainer" 
                        Background="Black"
                        MouseLeftButtonDown="ImageContainer_MouseLeftButtonDown"
                        MouseLeftButtonUp="ImageContainer_MouseLeftButtonUp"
                        MouseMove="ImageContainer_MouseMove"
                        MouseWheel="ImageContainer_MouseWheel">

            <Border x:Name="ImageBorder" 
                    BorderBrush="#33FFFFFF" 
                    BorderThickness="1" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ImgScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="ImgTranslate" X="0" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>

                <Border.Effect>
                    <local:LensCorrectionEffect x:Name="LensShader" DistortionAmount="0.0"/>
                </Border.Effect>

                <Image x:Name="MainImage" 
                       Stretch="Uniform" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       RenderOptions.EdgeMode="Aliased">
                </Image>
            </Border>
        </ContentControl>

        <Canvas x:Name="ReticleOverlay" IsHitTestVisible="False" Visibility="Collapsed">
            <Line Style="{StaticResource LineStyle}"
                  X1="0" 
                  Y1="{Binding ActualHeight, ElementName=RootGrid, Converter={StaticResource LayoutConverter}}" 
                  X2="{Binding ActualWidth, ElementName=RootGrid}" 
                  Y2="{Binding ActualHeight, ElementName=RootGrid, Converter={StaticResource LayoutConverter}}"/>
            <Line Style="{StaticResource LineStyle}"
                  X1="{Binding ActualWidth, ElementName=RootGrid, Converter={StaticResource LayoutConverter}}" 
                  Y1="0" 
                  X2="{Binding ActualWidth, ElementName=RootGrid, Converter={StaticResource LayoutConverter}}" 
                  Y2="{Binding ActualHeight, ElementName=RootGrid}"/>
        </Canvas>

        <Border x:Name="NotificationBadge" 
                Background="#EE16161B" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="10" 
                Padding="14,8" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,110"
                Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="20">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="4" Opacity="0.4"/>
            </Border.Effect>
            <TextBlock x:Name="NotificationText" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
        </Border>

        <Border x:Name="Sidebar" Width="280" HorizontalAlignment="Right"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                CornerRadius="16" Margin="0,16,16,16" Panel.ZIndex="10">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="28" ShadowDepth="6" Direction="180" Opacity="0.45"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="SidebarTransform" X="320"/>
            </Border.RenderTransform>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,24,20,20">
                    <TextBlock Text="ZiView" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="SETTINGS" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,2,0,20"/>

                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="表示" Style="{StaticResource SectionLabel}"/>
                            <CheckBox x:Name="CheckSpread" Content="見開き表示（右開き）" IsChecked="False" Click="OnSettingChanged"/>
                            <CheckBox x:Name="CheckAutoDetect" Content="ページ順の自動判定" IsChecked="False" Click="OnSettingChanged"/>
                            <CheckBox x:Name="CheckReticle" Content="レティクル表示" IsChecked="False" Click="OnReticleSettingChanged"/>
                            <CheckBox x:Name="CheckPrefetch" Content="AI先読み" IsChecked="True" Margin="0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="AIモデル" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Text="特性・用途" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CategoryComboBox" SelectionChanged="CategoryComboBox_SelectionChanged" Margin="0,0,0,12"/>
                            <TextBlock Text="モデル" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,6"/>
                            <ComboBox x:Name="ModelComboBox" SelectionChanged="ModelComboBox_SelectionChanged" Margin="0,0,0,10"/>
                            <Button Content="このモデルを除外" HorizontalAlignment="Right" FontSize="11" Padding="10,5"
                                    Click="ExcludeModelButton_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="レンズ補正 (K)" Style="{StaticResource SectionLabel}"/>
                            <CheckBox x:Name="CheckLens" Content="補正を有効化" IsChecked="False" Click="OnLensSettingChanged"/>
                            <TextBlock Text="補正量  [ / ]" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,8"/>
                            <Slider x:Name="LensSlider" Minimum="-2.0" Maximum="2.0" Value="0.40" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="AI分割比率" Style="{StaticResource SectionLabel}"/>
                            <Slider x:Name="SplitSlider" Minimum="0" Maximum="100" Value="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="カスタム背景色" Style="{StaticResource SectionLabel}"/>
                            <Border CornerRadius="8" ClipToBounds="True" Margin="0,0,0,10">
                                <Canvas x:Name="ColorPickerSvCanvas" Width="236" Height="150"
                                        Background="{x:Null}"
                                        MouseLeftButtonDown="OnSvCanvas_MouseDown"
                                        MouseMove="OnSvCanvas_MouseMove"/>
                            </Border>
                            <Slider x:Name="SliderHue" Minimum="0" Maximum="360" Value="0"
                                    ValueChanged="OnHueSlider_ValueChanged"/>
                            <TextBlock x:Name="HsvValueText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,10,0,0" Text="H: 0°, S: 0%, V: 0%"/>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="8" Margin="0,0,10,0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                    <Rectangle x:Name="PreviewColorBox" Height="32" Fill="#000000" RadiusX="7" RadiusY="7"/>
                                </Border>
                                <Button Content="適用" Grid.Column="1" Click="OnApplyCustomColorClick"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardPanel}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="システムモニター" Style="{StaticResource SectionLabel}"/>
                            <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <TextBlock x:Name="MemoryText" Text="RAM: -- MB" Foreground="{StaticResource AccentBrush}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border x:Name="BottomBar" Height="64" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                Background="#EE121216" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                CornerRadius="20" Margin="40,0,40,20" Panel.ZIndex="10">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="8" Direction="270" Opacity="0.5"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="BottomBarTransform" Y="110"/>
            </Border.RenderTransform>
            <DockPanel Margin="28,0">
                <TextBlock x:Name="PageText" Text="P.0 / 0" VerticalAlignment="Center" Width="110"
                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14"/>
                <Slider x:Name="PageSlider" VerticalAlignment="Center" IsDirectionReversed="True" Minimum="0" Maximum="0" Margin="14,0,0,0"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>